{
  "model_name": "deepEncoder-model",
  "dataset_name": "zeros-poles-dataset",
  "feature_list": [64, 128, 256, 512, 1024],
  "mask_halfwindow": 8,
  "mask_threshold": 0.4,
  "checkpoints_save_policy": "best",
  "checkpoints_metric": "dice",
  "early_stop_number": 50,
  "workers": 4,
  "input_size": [2, 512],
  "base_lr": 0.001,
  "weight_decay": 0.0001,
  "solver_type": "Adam",
  "batch_size": 144,
  "epochs": 200,
  "scheduler_on": false,
  "scheduler_patience": 30
}