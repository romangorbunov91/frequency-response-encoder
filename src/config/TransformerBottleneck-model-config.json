{
  "model_name": "TransformerBottleneck-model",
  "dataset_family": "zeros-poles-dataset",
  "dataset_name": "zeros-poles-dataset-very-noisy-deg",
  "feature_list": [32, 64, 128, 256, 512],
  "mask_halfwindow": 8,
  "mask_threshold": 0.5,
  "bce_weight": 0.25,
  "dice_weight": 0.75,
  "checkpoints_save_policy": "best",
  "checkpoints_metric": "dice",
  "early_stop_number": 50,
  "workers": 4,
  "input_size": [4, 512],
  "base_lr": 0.00001,
  "weight_decay": 0.0001,
  "solver_type": "Adam",
  "batch_size": 360,
  "epochs": 5000,
  "scheduler_on": true,
  "scheduler_patience": 30
}